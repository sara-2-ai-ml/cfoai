# --- Ports (local dev) ---
# CFOai (Next.js): open the URL shown in terminal as "Local:" — usually http://localhost:3000
# CHROMA_URL must match your Chroma server (local Docker default below).
# Start Chroma + Next together: npm run dev:full  (requires Docker)

# Anthropic (chat / summary / compare)
ANTHROPIC_API_KEY=
# Optional model override
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI (embeddings, charts)
OPENAI_API_KEY=

# ChromaDB
CHROMA_URL=http://localhost:8000
# Optional — when using Chroma Cloud or secured instance
CHROMA_API_KEY=
CHROMA_TENANT=

# Vercel Blob (optional file storage; not required for local upload flow)
BLOB_READ_WRITE_TOKEN=

# Clerk (auth — required for /dashboard, /sign-in, /sign-up)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk Dashboard → configure URLs for your app origin, e.g. http://localhost:3000 (must match the port you use)

# Next.js 15 — keep stable across `next dev` / rebuilds so Server Action IDs match the client (avoids
# UnrecognizedActionError when using libraries that register actions, e.g. @clerk/nextjs). Generate once:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
