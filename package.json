{
  "name": "cfoai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "dev": "node scripts/ensure-fallback-build-manifest.cjs && node scripts/print-ports.cjs && next dev -p 3000",
    "dev:clean": "npm run clean && node scripts/print-ports.cjs && next dev -p 3000",
    "chroma:up": "docker compose up",
    "dev:full": "node scripts/dev-full.cjs",
    "fix:next-manifest": "node scripts/ensure-fallback-build-manifest.cjs",
    "build": "next build",
    "postbuild": "node scripts/ensure-fallback-build-manifest.cjs",
    "build:clean": "npm run clean && next build",
    "start": "next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@clerk/nextjs": "^7.3.3",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.92",
    "chromadb": "^3.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.511.0",
    "next": "^15.0.0",
    "openai": "^4.77.3",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.0",
    "three": "^0.173.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "wait-on": "^9.0.10"
  }
}
